<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{cv.candidate.name}} - {{application.role}}</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            font-size: 9pt;
            line-height: 1.3;
            color: #1a1a1a;
            background: #fff;
        }

        .page {
            width: 210mm;
            min-height: 297mm;
            max-height: 297mm;
            padding: 14mm 15mm 14mm 20mm;
            margin: 0 auto;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .page-inner {
            width: 100%;
            transform-origin: top left;
            will-change: transform;
        }

        header {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 12px;
            padding-bottom: 10px;
            border-bottom: 1.5px solid #333;
        }

        .photo {
            width: 70px;
            height: 85px;
            border-radius: 4px;
            object-fit: cover;
            flex-shrink: 0;
        }

        .header-content {
            flex: 1;
            text-align: center;
        }

        h1 {
            font-size: 20pt;
            font-weight: 600;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }

        .contact {
            font-size: 8.5pt;
            color: #444;
        }

        .contact a {
            color: #2563eb;
            text-decoration: none;
        }

        .contact-links span:not(:last-child)::after {
            content: " | ";
            color: #444;
        }

        .summary {
            margin-bottom: 14px;
            padding: 8px 12px;
            background: #f8f9fa;
            border-left: 3px solid #333;
            font-size: 8.5pt;
            color: #333;
        }

        section {
            margin-bottom: 12px;
        }

        h2 {
            font-size: 10pt;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #1a1a1a;
            border-bottom: 1px solid #ccc;
            padding-bottom: 2px;
            margin-bottom: 6px;
        }

        .company {
            margin-bottom: 12px;
        }

        .company-header {
            font-weight: 600;
            font-size: 9.5pt;
            color: #1a1a1a;
        }

        .company-desc {
            font-size: 8pt;
            font-style: italic;
            color: #555;
            margin-bottom: 4px;
        }

        .role {
            margin-bottom: 8px;
        }

        .role-title {
            font-weight: 600;
            font-size: 9pt;
            color: #333;
        }

        .role-period {
            font-size: 8pt;
            color: #666;
            margin-bottom: 2px;
        }

        ul {
            margin-left: 14px;
            margin-bottom: 4px;
        }

        li {
            font-size: 8pt;
            margin-bottom: 2px;
            color: #333;
        }

        .two-column {
            display: flex;
            gap: 20px;
            flex: 1;
            align-content: flex-start;
        }

        .two-column > div {
            flex: 1;
        }

        .side-projects h3 {
            font-size: 9pt;
            font-weight: 600;
            color: #333;
            margin-bottom: 2px;
        }

        .side-projects p {
            font-size: 8pt;
            color: #444;
            margin-bottom: 4px;
        }

        .side-projects a {
            color: #2563eb;
            text-decoration: none;
        }

        .education h3 {
            font-size: 9pt;
            font-weight: 600;
            color: #333;
        }

        .education .degree {
            font-size: 8pt;
            color: #444;
        }

        .education .period {
            font-size: 7.5pt;
            color: #666;
        }

        .skills-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 4px 12px;
            font-size: 8pt;
        }

        .skill-category {
            margin-bottom: 2px;
        }

        .skill-category strong {
            color: #333;
        }

        .skill-category span {
            color: #555;
        }

        .languages {
            font-size: 8pt;
            color: #444;
        }

        .languages span:not(:last-child)::after {
            content: " | ";
        }

        @media print {
            html, body {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            .page {
                padding: 12mm 12mm 12mm 18mm;
                margin: 0;
            }

            a {
                color: #000 !important;
                text-decoration: none;
            }

            .summary {
                background: #f0f0f0 !important;
                border-left-color: #000 !important;
            }
        }

        @media print and (monochrome) {
            .summary {
                background: #eee !important;
            }
        }
    </style>
</head>
<body>
    <div class="page">
        <div class="page-inner" id="page-inner">
            <header>
{{#if photoSrc}}
                <img src="{{photoSrc}}" alt="{{cv.candidate.name}}" class="photo">
{{/if}}
                <div class="header-content">
                    <h1>{{cv.candidate.name}}</h1>
                    <div class="contact">
                        {{cv.candidate.location}} |
                        <a href="mailto:{{cv.candidate.email}}">{{cv.candidate.email}}</a> |
                        {{cv.candidate.phone}}<br>
                        <span class="contact-links">
{{#each cv.candidate.links}}
                            <span><a href="{{url}}">{{label}}</a></span>
{{/each}}
                        </span>
                    </div>
                </div>
            </header>

            <div class="summary">
                {{cv.summary}}
            </div>

            <section>
                <h2>Experience</h2>
{{#each cv.experience}}
                <div class="company">
                    <div class="company-header">{{name}}{{#if location}} - {{location}}{{/if}}</div>
{{#if description}}
                    <div class="company-desc">{{description}}</div>
{{/if}}
{{#each roles}}
                    <div class="role">
                        <div class="role-title">{{title}}</div>
                        <div class="role-period">{{period}}</div>
                        <ul>
{{#each items}}
                            <li>{{this}}</li>
{{/each}}
                        </ul>
                    </div>
{{/each}}
                </div>
{{/each}}
            </section>

            <div class="two-column">
                <div>
{{#if cv.sideProjects}}
                    <section class="side-projects">
                        <h2>Side Projects</h2>
{{#each cv.sideProjects}}
                        <h3>{{title}}</h3>
                        <p>{{description}}{{#if link.url}} <a href="{{link.url}}">{{link.text}}</a>{{/if}}</p>
{{/each}}
                    </section>
{{/if}}

                    <section class="education">
                        <h2>Education</h2>
                        <h3>{{cv.education.school}}</h3>
                        <div class="degree">{{cv.education.degree}}</div>
                        <div class="period">{{cv.education.period}}</div>
                    </section>
                </div>

                <div>
                    <section>
                        <h2>Skills</h2>
                        <div class="skills-grid">
{{#each cv.skills}}
                            <div class="skill-category"><strong>{{name}}:</strong> <span>{{join items ", "}}</span></div>
{{/each}}
                        </div>
                    </section>

                    <section>
                        <h2>Languages</h2>
                        <div class="languages">
{{#each cv.languages}}
                            <span><strong>{{name}}:</strong> {{level}}</span>
{{/each}}
                        </div>
                    </section>
                </div>
            </div>
        </div>
    </div>

    <script>
        (function () {
            function fitToA4() {
                var page = document.querySelector('.page');
                var inner = document.getElementById('page-inner');
                if (!page || !inner) return;

                inner.style.transform = 'scale(1)';

                var pageStyle = window.getComputedStyle(page);
                var paddingTop = parseFloat(pageStyle.paddingTop) || 0;
                var paddingBottom = parseFloat(pageStyle.paddingBottom) || 0;
                var availableHeight = page.clientHeight - paddingTop - paddingBottom;
                var contentHeight = inner.scrollHeight;

                if (contentHeight > availableHeight) {
                    var scale = Math.max(0.1, (availableHeight - 2) / contentHeight);
                    inner.style.transform = 'scale(' + scale + ')';
                }
            }

            window.addEventListener('load', fitToA4);
            window.addEventListener('resize', fitToA4);
            window.addEventListener('beforeprint', fitToA4);
            if (document.fonts && document.fonts.ready) {
                document.fonts.ready.then(fitToA4);
            }
        })();
    </script>
</body>
</html>
